# 开发环境配置 - 面试虎
# 复制此文件为 .env 并填入你的真实配置

APP_ENV=development
APP_DEBUG=true

# 火山引擎方舟大模型
# 获取位置：火山引擎控制台 → 火山方舟 → 模型广场 → 右上角头像 → API Key
ARK_API_KEY=your_ark_api_key_here
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎知识库
# KB_PROVIDER: 选择知识库类型，local（本地ChromaDB）或 volcengine（火山引擎云端）
KB_PROVIDER=local
# 获取位置：火山引擎控制台 → 向量数据库 VikingDB → 知识库 → 右上角头像 → 用户管理 → API Key
# 注意：KB_API_KEY 使用 VIKING_API_KEY（纯字母数字），不是 AK:SK 格式
KB_API_KEY=your_viking_api_key_here
# 获取位置：知识库列表 → 目标知识库 → 知识库 ID（kb-xxx 格式）
KB_ID=your_knowledgebase_id_here
KB_PROJECT=default
KB_BASE_URL=https://api-knowledgebase.mlp.cn-beijing.volces.com

# 联网搜索（知识库无结果时的降级方案）
# 方式1（推荐）：在方舟控制台创建Bot应用并开通联网插件，获取bot-xxx格式的ID填入
# 方式2：留空则尝试通过 enable_search 参数开启（部分模型支持）
# WEB_SEARCH_BOT_ID=

# 火山引擎语音识别（ASR）
# 前往 https://console.volcengine.com/speech/service/ 开通并获取
ASR_APP_ID=your_asr_app_id
ASR_TOKEN=your_asr_token

# 服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
