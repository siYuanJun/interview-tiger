# 开发环境配置 - 面试虎
# 复制此文件为 .env 并填入你的真实配置

APP_ENV=development
APP_DEBUG=true

# 火山引擎方舟大模型
ARK_API_KEY=your_api_key_here
ARK_MODEL=your_model_id_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎知识库
KB_API_KEY=your_ak_sk_here
KB_ID=your_kb_id_here
KB_PROJECT=default
KB_BASE_URL=https://api-knowledgebase.mlp.cn-beijing.volces.com

# 联网搜索（知识库无结果时的降级方案）
# 方式1（推荐）：在方舟控制台创建Bot应用并开通联网插件，获取bot-xxx格式的ID填入
# 方式2：留空则尝试通过 enable_search 参数开启（部分模型支持）
# WEB_SEARCH_BOT_ID=

# 服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
