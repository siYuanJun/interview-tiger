# 开发环境配置 - 面试虎
# 复制此文件为 .env 并填入你的真实配置

APP_ENV=development
APP_DEBUG=true

# 火山引擎方舟大模型
ARK_API_KEY=your_api_key_here
ARK_MODEL=your_model_id_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎知识库
KB_API_KEY=your_ak_sk_here
KB_ID=your_kb_id_here
KB_PROJECT=default
KB_BASE_URL=https://api-knowledgebase.mlp.cn-beijing.volces.com

# 服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
